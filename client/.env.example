# Copy to .env.local for local dev (optional — the vite dev proxy handles /api).
# On Vercel, set VITE_API_URL in the project's Environment Variables to
# the full origin of your Render API, e.g.
#   VITE_API_URL=https://lps-mis-api.onrender.com
#
# The client prefixes this with /api automatically — do NOT include /api here.
VITE_API_URL=
