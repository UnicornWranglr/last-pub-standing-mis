# Copy this file to .env and fill in real values before running docker compose up.
# This file is ONLY used for local Docker Compose. On Render, set these in the
# Render dashboard (most come from render.yaml automatically).

# ── Postgres ─────────────────────────────────────────────────────────────────
DB_USER=pub
DB_PASSWORD=change-me-to-a-long-random-string
DB_NAME=pub_mis

# ── JWT signing ──────────────────────────────────────────────────────────────
# Generate a long random string, e.g. `openssl rand -hex 64`
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed client origins. Leave empty for local dev
# (all origins allowed). In production this MUST be set to your Vercel URL,
# e.g. https://lps-mis.vercel.app
CLIENT_URL=

# ── Seeded users (created on first boot, idempotent) ─────────────────────────
# Simon = owner, Karen = manager, Daniel = staff. Change these passwords
# immediately after first login. Passwords are only used if the user
# doesn't already exist.
SEED_OWNER_USERNAME=simon
SEED_OWNER_PASSWORD=change-me-on-first-login
SEED_MANAGER_USERNAME=karen
SEED_MANAGER_PASSWORD=change-me-on-first-login
SEED_STAFF_USERNAME=daniel
SEED_STAFF_PASSWORD=change-me-on-first-login
